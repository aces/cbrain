  <% @groups = @groups.to_a.unshift('ALL')%>
  <%=
    dynamic_scoped_table(@groups,
      :id         => 'groups_table',
      :class      => [ :resource_list ],
      :scope      => @scope,
      :order_map  => {
        :site    => { :a => 'sites.name',  :j => Site },
        :creator => { :a => 'users.login', :j => User }
      },
      :filter_map => {
        :site    => { :a => 'site_id'    },
        :creator => { :a => 'creator_id' }
      }
    ) do |t|
      t.paginate

      t.row do |g|
        next unless (g == "ALL")
        switch = link_to t('switch'), { :action => :switch, :id => "all"},
                                    :class   => 'action_link',
                                    :method  => :post
        row_content =
          {:name           => t('groups.common.all'),
           :description    => t('.represents_all_projects'),
           :type           => t('.all_projects'),
           :site           => "",
           :creator_id     => "",
           :users          => "",
           :files          => @group_id_2_userfile_counts[nil] || "(#{t('none')})",
           :tasks          => @group_id_2_task_counts[nil] || "(#{t('none')})",
           :switch         => switch,
          }
        {
          :override => lambda { |g,r,t|
            row_content.map { |k,v|
              "<td class=\"#{k}\" data-column=\"#{k}\">#{v}</td>"}.join.html_safe
          }
        }
      end

      t.column(t('activerecord.attributes.name'), :name,
        :sortable => true
      ) { |g| link_to_group_if_accessible(g) }

      t.column(t('activerecord.attributes.description'), :description,
        :sortable => true,
      ) { |g| overlay_description(g.description) }

      t.column(t('.project_type'), :type,
        :sortable => true,
        :filters  => default_filters_for(@base_scope, :type)
      ) { |g| g.pretty_category_name(current_user) }

      t.column(t('activerecord.models.site.one'), :site,
        :sortable => true,
        :filters  => default_filters_for(@base_scope, Site)
      ) { |g| link_to_site_if_accessible(g.site) }

      t.column(t('groups.common.creator'), :creator_id,
        :sortable => true,
        :filters => scoped_filters_for(
          @base_scope, @view_scope, :creator_id,
          scope: @scope,
          label: 'users.login',
          association: [User, 'id', 'creator_id']
        )
      ) { |g| link_to_user_if_accessible(g.creator) }

      t.column(t('activerecord.models.user.other'), :users) do |g|
        @group_id_2_user_counts[g.id].to_s.presence || html_colorize("(#{t('none')})", "red")
      end
      t.column(t('activerecord.models.userfile.other'), :files) do |g|
        index_count_filter @group_id_2_userfile_counts[g.id], :userfiles, { :group_id => g.id }, :show_zeros => true
      end
      t.column(t('activerecord.models.cbrain_task.other'), :tasks) do |g|
        index_count_filter @group_id_2_task_counts[g.id], :tasks, { :group_id => g.id }, :show_zeros => true
      end

      t.column(t('switch'), :switch) do |g|
        link_to t('switch'), { :action => :switch, :id => g.id },
          :class   => 'action_link',
          :method  => :post
      end
    end
  %>
