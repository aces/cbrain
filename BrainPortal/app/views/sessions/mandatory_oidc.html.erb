<% title t('.title') %>

<h2><%= t('.before_message_html') %></h2>

<h5><%= t('.explanations') %></h5>

<p class="short_paragraphs">
  <%= t('.p_explanations') %>
</p>

<h5><%= t('.allowed_providers') %></h5>

<ul>
  <% @allowed_prov_names.each do |provname| %>
    <% provname = t('.any_provider') if provname == '*' %>
    <li><%= provname %></li>
  <% end %>
</ul>


<% if @oidc_configs.empty? %>
  <p class="short_paragraphs">
    <%= t('.p_no_provider') %>
  </p>
<% end %>

<% @oidc_configs.each do |oidc| %>
  <%= link_to t('.login_with', name: oidc.name), @oidc_uris[oidc.name], :class => 'button globus_button' %></br></br>
<% end %>

<% if !@oidc_configs.empty? %>
<p class="short_paragraphs">
  <%= t('.p_already_logged_in') %>
<p>
<% end %>

<% @oidc_configs.each do |oidc| %>
  <%= link_to t('.logout_from', name: oidc.name), oidc.logout_uri, :class => 'button globus_button' %></br></br>
<% end %>

