<!-- State information -->

<% @filelist.each do |id| %>
  <%= hidden_field_tag "file_ids[]", id %>
<% end %>

<%= hidden_field_tag :index, @current_index %>

<!-- User control buttons -->

  <fieldset class="display_inline_block">
    <legend><%= t('.navigation_info', current: @current_index + 1, total: @filelist.size) %></legend>
    <%= link_to_userfile_if_accessible(@userfile, current_user, :html_options => { :target => '_blank' }) %>
    <p>
    <% not_first_file = @current_index != 0 %>
    <% not_last_file  = @current_index < @filelist.size - 1 %>
    <% if  not_first_file %>
      <%= submit_button t('.previous_file'), :name => :previous %>
    <% end %>
    <% if not_last_file %>
      <%= submit_button t('.next_file'), :name => :next %>
    <% end %>
  </fieldset>

  <br>

  <fieldset class="display_inline_block">
    <legend><%= t('.file_tags') %></legend>
    <%= submit_button t('.pass'),    :name => :pass %>
    <%= submit_button t('.fail'),    :name => :fail %>
    <%= submit_button t('unknown').downcase, :name => :unknown %>
    <br>
    <%= t('.full_list_of_tags') %><br>
    <select name="tag_ids[]" multiple="multiple" style="width: 15em" size="4" >
      <%= options_from_collection_for_select current_user.available_tags, 'id', 'name',
          @userfile.get_tags_for_user(current_user).ids %>
    </select>
  </fieldset>

  <fieldset class="display_inline_block">
    <legend><%= t('.file_description') %></legend>
    <%= text_area_tag "userfile[description]", @userfile.description, :rows => 5, :cols => 40 %>
  </fieldset>

<p>

<% update_message  = t('update') %>
<% update_message += t('userfiles.common.and_go') if not_last_file %>
<%= submit_tag "#{update_message}", :name => :update, :data => {:current_file_id => @userfile.id } %>

<hr>

<!-- Custom QC content for the userfile -->

<% begin %>
  <%= render :file => @qc_view_file %>
<% rescue => ex %>
  <%= t('.qc_error') %>
  <% if current_user.has_role? :admin_user %>
    <pre>
    <%= t('userfiles.common.exception') %> <%= ex.class %> : <%= ex.message %>
    <% ex.backtrace.each do |line| %>
    <%= line %>
    <% end %>
    </pre>
  <% end %>
<% end %>
