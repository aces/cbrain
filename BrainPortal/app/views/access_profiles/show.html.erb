<% title @access_profile.new_record? ? t('.add_new_access_profile') : t('activerecord.models.access_profile.one')  %>
<% if @access_profile.id %>
  <div class="menu_bar">
    <%= link_to t('delete'), access_profile_path(@access_profile),  {
          :data => { :confirm => t('confirm_delete', name: @access_profile.name) } ,
          :method  => :delete,
          :class => "button"
          }
    %>
    <%= overlay_ajax_link t('help'), "/doc/access_profiles/access_profiles.html", :class  => "button" %>
  </div>
<% end %>
<br>
<%= error_messages_for @access_profile, :header_message => t('.saved_error', action: @access_profile.new_record? ? t('saved') : t('updated')) %>

<div class="display_inline_block" style="min-width: 50%">

<%= show_table_context(@access_profile) do |cf| %>

  <%= show_table(@access_profile, :form_helper => cf, :edit_condition => check_role(:admin_user)) do |t| %>

    <% t.edit_cell(:name, :header => t('activerecord.attributes.name'), :content => access_profile_label(@access_profile), :show_width => 2) do |f| %>
      <%= f.text_field :name, :class => "cb_colorpick_bg_target" %>
    <% end %>

    <% t.edit_cell(:color, :header => t('activerecord.attributes.color'), :show_width => 2) do |f| %>
      <%= f.text_field :color, :class => "cb_colorpick_val_target" %><br>
      <span class="field_explanation"><%= t('.css_explanation_html') %></span><br>
      <%= render :partial => 'shared/color_picker', :locals => { :step => 30, :greys => false, :dark => false } %>
    <% end %>

    <% t.edit_cell(:description, :header => AccessProfile.human_attribute_name(:description), :content => full_description(@access_profile.description), :show_width => 2 ) do |f| %>
      <%= f.text_area :description, :rows => 6, :cols => 60 %><br/>
      <span class="field_explanation"><%= t('.private_note') %></span>
    <% end %>

  <% end %>

  <% myusers = @access_profile.users.all.sort_by(&:login) %>

<%= show_table(@access_profile, :form_helper => cf, :edit_condition => check_role(:admin_user), :header => (@access_profile.new_record? ? t('.project_membership') : t('.projects_in_this_profile'))) do |t| %>
    <% group_names = (@access_profile.groups.sort_by(&:name).map { |g| link_to_group_if_accessible(g) }.join(", ").html_safe.presence) || t('none') %>
    <% t.edit_cell(:group_ids, :show_width => 2, :no_header => Group.model_name.human(count: 2), :td_options => { :class => "wrap" }, :content => group_names) do %>

      <%= render :partial => 'shared/group_tables', :locals => { :model => @access_profile } %>

      <% if myusers.present? %>
        <p>
        <hr>
        <p>
          <%= t('.change_note') %>
          <%= select_all_checkbox "all_affected_users", :id => "togall", :checked => "1" %>
          <%= render :partial => 'shared/users_checkbox_table',
                     :locals => {
                                :users         => myusers,
                                :checked       => myusers,
                                :variable_name => "affected_user_ids[]",
                                :html_class    => "all_affected_users",
                              }
          %>
      <% end %>
    <% end %>
  <% end %>

  <% if !@access_profile.new_record? %>
    <%= show_table(@access_profile, :form_helper => cf, :edit_condition => check_role(:admin_user), :header => t('.with_this_profile') ) do |t| %>

      <% if myusers.present? && myusers.count > 0 %>
        <% user_names = (array_to_table(myusers.map { |u| link_to_user_if_accessible(u) }, :table_class => 'simple', :cols => 12).html_safe) %>
      <% else %>
        <% user_names = t('none') %>
      <% end %>

      <% t.edit_cell(:user_ids, :show_width => 2, :no_header => User.model_name.human(count: 2), :content => user_names) do %>

        <%= t('.normal_users') %><br>
        <%= render :partial => 'shared/users_checkbox_table',
                  :locals => {
                                :users         => User.where(:account_locked => false).order(:login).all,
                                :checked       => myusers,
                                :variable_name => "access_profile[user_ids][]",
                              }
        %>

        <br>
        <%= t('.locked_users') %><br>
        <%= render :partial => 'shared/users_checkbox_table',
                  :locals => {
                                :users         => User.where(:account_locked => true).order(:login).all,
                                :checked       => myusers,
                                :variable_name => "access_profile[user_ids][]",
                              }
        %>

      <% end %>
    <% end %>
  <% end %>

<% end # show_table_context %>

  <p>
  <%= render :partial => "layouts/log_report", :locals  => { :log  => @access_profile.getlog, :title => t('.access_profile_log') } %>

</div>
