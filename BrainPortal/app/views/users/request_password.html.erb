<% title t('.title') %>

<h2><%= t('.lost_password') %></h2>

<%= form_tag send_password_users_path do %>
  <table id="request_password" class="logintable">
    <tr>
      <td><label for="login"><%= t('.cbrain_login') %></label></td>
      <td class="field"><%= text_field_tag :login %></td>
    </tr>
    <tr>
      <td><label for="email"><%= t('.email_on_account') %></label></td>
      <td class="field"><%= text_field_tag :email %></td>
    </tr>
    <tr>
     <td></td>
     <td class="field"><br><%= submit_tag t('submit') %></td></td>
    </tr>
  </table>
<% end %>

