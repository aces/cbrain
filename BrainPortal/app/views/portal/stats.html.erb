<% title t('.title') %>

  <h1><%= t('.header') %></h1>

  <div class="generalbox">
    <table>
      <!-- header -->
      <tr>
        <th colspan="3" class="supertitle"><%= t('.total_by_client') %></th>
      </tr>
      <tr>
        <th><%= t('.client_type') %></th>
        <th><%= t('.successes') %></th>
        <th><%= t('.failures') %></th>
      </tr>
      <!-- each row -->
      <% @stats_by_client.keys.sort.each do |client| %>
        <% counts = @stats_by_client[client] %>
        <tr>
          <td><%= client %></td>
          <td><%= counts[0] %></td>
          <td><%= counts[1] %></td>
        </tr>
      <% end %>
    </table>
  </div>

  <div class="box_spacer"></div>

  <div class="generalbox">
    <table>
      <!-- header -->
      <tr>
        <th colspan="4" class="supertitle"><%= t('.totals_by_controller_html') %></th>
      </tr>
      <tr>
        <th><%= t('.controller') %></th>
        <th><%= t('.action') %></th>
        <th><%= t('.successes') %></th>
        <th><%= t('.failures') %></th>
      </tr>
      <!-- each row -->
      <% @stats_by_contr_action.keys.sort.each do |contr_action| %>
        <% counts            = @stats_by_contr_action[contr_action] %>
        <% controller,action = contr_action.split(",") %>
        <tr>
          <td><%= controller %></td>
          <td><%= action %></td>
          <td><%= counts[0] %></td>
          <td><%= counts[1] %></td>
        </tr>
      <% end %>
    </table>
  </div>

  <div class="box_spacer"></div>

  <div class="generalbox">
    <table class="report">
      <!-- header -->
      <tr>
        <th colspan="2" class="supertitle"><%= t('.total_by_status') %></th>
      </tr>
      <tr>
        <th><%= t('.status_code') %></th>
        <th><%= t('.count') %></th>
      </tr>
      <!-- each row -->
      <% bystatus = @stats['StatusCodes'] || {} %>
      <% bystatus.keys.sort.each do |status_code| %>
        <% code  = status_code =~ /(\d+)\z/ ? Regexp.last_match[1] : status_code %>
        <% count = bystatus[status_code] || "((#{t('unknown')}))" %>
        <tr>
          <td><%= code %></td>
          <td><%= count %></td>
        </tr>
      <% end %>
    </table>
  </div>

  <p>

  <strong><%= t('.last_reset') %></strong> <%= @last_reset %>


