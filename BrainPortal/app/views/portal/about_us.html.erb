<% title t('.title') %>

<div class="credit_box">

  <h3><%= t('.header') %></h3>
  <strong><%= t('version.one') %></strong> <%= @revinfo['Revision'] %>
  <br>
  <strong><%= t('.last_author') %></strong> <%= @revinfo['Last Changed Author'] %>
  <br>
  <strong><%= t('.last_revision') %></strong> <%= @revinfo['Last Changed Rev'] %>
  <br>
  <strong><%= t('.last_changed') %></strong> <%= to_localtime(@revinfo['Last Changed Date'],:datetime) %>
  <br>
  <strong><%= t('.up_since') %></strong> <%= to_localtime(CBRAIN::Startup_LocalTime,:datetime) %> (<%= t('for') %> <%= pretty_elapsed((Time.now.localtime - CBRAIN::Startup_LocalTime).to_i) %>)

  <% plugins_basenames = Pathname(CBRAIN::Plugins_Dir)
                         .children
                         .select(&:directory?)
                         .map(&:basename)
                         .map(&:to_s)
                         .reject { |x| x =~ /test|^cbrain-plugins-base$|^installed-plugins$/ }
                         .sort
  %>

  <% if plugins_basenames.present? %>
    <h3><%= t('.plugins_revision_header') %>
    <%= show_hide_toggle "(#{t('show')})", "#plugins_panel", :class  => 'action_link' %>
    </h3>
    <div id="plugins_panel" style="display: none">
    <% plugins_basenames.sort.each do |plugin| %>
      <% revtag  = CbrainFileRevision.cbrain_head_tag(plugin)                 rescue CbrainFileRevision::DEFAULT_TAG %>
      <% revinfo = CbrainFileRevision.cbrain_head_revinfo(plugin).self_update rescue nil %>
      <h5><%= t('.plugins_package', plugin.sub("cbrain-plugins-","").capitalize)  %></h5>
      <strong><%= t('version.one') %></strong> <%= revtag %>
      <br>
      <strong><%= t('.last_author') %></strong> <%= revinfo.try(:author) || "?" %>
      <br>
      <strong><%= t('.last_revision') %></strong> <%= revinfo.try(:commit) || "?" %>
      <br>
      <strong><%= t('.last_changed') %></strong> <%= revinfo ? to_localtime(revinfo.datetime) : "?" %>
      <p>
    <% end %>
    </div>
  <% end %>

  <% if current_user && current_user.has_role?(:admin_user) %>
    <h3><%= t('.platform_info') %>
    <%= show_hide_toggle "(#{t('show')})", "#platform_panel", :class  => 'action_link' %>
    </h3>
    <div id="platform_panel" style="display: none">
      <%= Rails::Info.to_html.html_safe %>
    </div>
    <h3><%= t('.env_vars') %>
    <%= show_hide_toggle "(#{t('show')})", "#env_panel", :class  => 'action_link' %>
    </h3>
    <div id="env_panel" style="display: none">
      <%= array_to_table(ENV.to_a.sort { |a,b| a[0] <=> b[0] }.flatten, :cols => 2, :td_class => 'left') %>
    </div>
  <% end %>
</div>

<div class="box_spacer"></div>

<div class="credit_box">
  <h3><%= t('.licensing_info') %></h3>

  <%=
    t('.credits_link_html',
      credits_link: link_to(t('.credits'), "/credits", class: "action_link"),
      github_link:  link_to(t('.github_contributors'), "https://github.com/aces/cbrain/graphs/contributors", class: "action_link")
    )
  %>

  <p>

  <fieldset>
    <legend>
     <%= t('.gnu_license') %>
    </legend>
    <%= t('.gnu_desc_html') %>
    <%= show_hide_toggle "(#{t('show')})", "#gpl_panel", :class  => 'action_link' %>
    <div id="gpl_panel" style="display: none">
      <pre>
      <% txt = File.read(Rails.root.to_s + "/../LICENSE.txt") rescue t('.error_getting_license') %>
      <%= txt %>
      </pre>
    </div>
  </fieldset>
  <fieldset>
    <legend>
      <%= t('.other_licenses') %>
    </legend>
    <%= t('.other_desc_html') %>

    <%= show_hide_toggle "(#{t('show')})", "#other_licenses_panel", :class  => 'action_link' %>
    <div id="other_licenses_panel" style="display: none">
      <pre>
      <% txt = File.read(Rails.root.to_s + "/../CBRAIN_licenses.txt") rescue t('.error_getting_license') %>
      <%= txt %>
      </pre>
    </div>
  </fieldset>
</div>

<%= render :partial => 'logo_footer' %>

