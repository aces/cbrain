<!-- ************************ -->
<!-- PARTIAL: ACCOUNT SECTION -->
<!-- ************************ -->

<%
  # We can colorize the CBRAIN interface based on the current GIT branch
  # One only needs to define a CSS class 'account_git_branch_NAME'
  git_branch = CBRAIN::CBRAIN_Git_Branch.presence || t('unknown')
  # When devs are working in their own special branches, highlight the top in green
  colorstyle = 'style="background-color: #393"'.html_safe if git_branch !~ /^(dev|master|unknown|service)$/
%>

<div class="account account_git_branch_<%= git_branch.gsub(/\W/,"_") %>" <%= colorstyle %>>

  <span class="home_credits">
    <%= link_to 'NeuroHub', alternate_page_or_dashboard_path, :class => "home_credits-neurohub" %>
    <% if current_user %>
      <%= link_to t('.dashboard'), home_path %>
      <%= link_to t('.my_account'), user_path(current_user) %>
      <%= link_to t('activerecord.models.group.other'), groups_path %>
      <%
         message_link = t('activerecord.models.message.other')
         message_link = "#{message_link} <span class=\"message_count\">(#{@unread_message_count})</span>".html_safe if (@unread_message_count.presence || 0) > 0
      %>
      <%= link_to message_link, messages_path, :title => t('.unread_message', count: @unread_message_count) %>
      <% if current_user.has_role?(:normal_user) %>
        <%= hover_dropdown(t('.resource'), :dropdown_class => "resource_header") do %>
          <%= link_to t('activerecord.models.data_provider.other'), data_providers_path %><BR>
          <%= link_to t('layouts.common.quotas'), quotas_path %><BR>
          <%= link_to t('activerecord.models.remote_resource.other'), bourreaux_path %><BR>
          <%= link_to t('activerecord.models.tool.other'), tools_path %><BR>
          <%= link_to t('layouts.common.tool_versions'), tool_configs_path %><BR>
          <%= link_to t('layouts.common.usage'), resource_usage_index_path %><BR>
          <%= link_to t('.full_list'), available_path %><BR>
        <% end %>
      <% end %>
      <% help_url = RemoteResource.current_resource.help_url %>
      <% if help_url.present? %>
        <%= link_to t('.help_site'), help_url, :target => '_blank' %>
      <% end %>
      <% support_email = RemoteResource.current_resource.support_email %>
      <% if support_email.present? %>
        <%= html_tool_tip(mail_to(support_email, t('.email_support')), :offset_x => 0, :offset_y => 20) do %>
          <%= t('.email_support_tool_tip_html', email: support_email) %>
        <% end %>
      <% end %>
    <% end %>
    <%= t('.revision', rev: CBRAIN::CBRAIN_StartTime_Revision) %>
    <% if current_user.present? && current_user.has_role?(:admin_user) %>
      <%= t('.branch', name: git_branch) %>
    <% end %>
    <div>
      <%= link_to "EN", url_for(locale: 'en') %> /
      <%= link_to "FR", url_for(locale: 'fr') %>
    </div>
  </span>

  <span class="loggedas">
    <% if current_user %>
      <span class="last_updated"><%= (t('.last_updated_html', time: "0m")) %></span>

      <%= t('.as', name: current_user.full_name) %>
      <%= link_to t('.sign_out'), "/logout" %>
    <% else %>
      <%= link_to t('.sign_in'), "/login" %>
    <% end %>
  </span>

</div>

